# Server
PORT=4000
NODE_ENV=development

# PostgreSQL connection
# Either set DATABASE_URL, or the individual PG* vars below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cinevault

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=cinevault

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Seed admin account (created by `npm run db:seed`)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@cinevault.com
SEED_ADMIN_PASSWORD=Admin123!

# CORS
CLIENT_ORIGIN=http://localhost:5173
